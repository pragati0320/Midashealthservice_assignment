                  "pm.test(\"Response time less than 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.expect(",
                  "        pm.response.headers.get(\"Content-Type\")",
                  "    ).to.include(\"application/json\");",
